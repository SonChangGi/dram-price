{
  "version": 1,
  "projectId": "dram-price",
  "rootDir": ".",
  "targets": [
    {
      "id": "react-source",
      "path": "frontend/src",
      "mode": "source",
      "extensions": [".ts", ".tsx"]
    }
  ],
  "excludePaths": ["node_modules", "dist", "coverage"],
  "roleGates": ["hero-support", "section-support", "chart-instructions"],
  "minDuplicateLength": 24,
  "retainedVisibleCopy": [],
  "additionalBannedPatterns": [
    {
      "id": "dram-page-tour",
      "description": "DRAM 결과 순서를 설명하는 문구",
      "pattern": "현물가를 먼저 보고|제품별 흐름과 상세 관측치를 차례로"
    }
  ]
}
